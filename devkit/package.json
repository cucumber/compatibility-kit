{
  "name": "cck-devkit",
  "version": "11.0.0",
  "description": "Development kit for the cucumber compatibility kit packages",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "validate": "run-for-every-file --src 'samples/**/*.ndjson' --run 'npx shx cat {{src-file}} | node ./validate.mjs'",
    "generate-ndjson": "vitest run --update",
    "postgenerate-ndjson": "npm run validate && npm run copy-samples",
    "copy-samples": "npm run copy-to:javascript && npm run copy-to:ruby",
    "copy-to:javascript": "shx cp -r samples/* ../javascript/features",
    "copy-to:ruby": "shx cp -r samples/* ../ruby/features && rm -rf ../ruby/features/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cucumber/compatibility-kit.git"
  },
  "author": "Aurelien Reeves (https://github.com/aurelien-reeves)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cucumber/compatibility-kit/issues"
  },
  "homepage": "https://github.com/cucumber/compatibility-kit#readme",
  "dependencies": {
    "@cucumber/ci-environment": "^10.0.1",
    "@cucumber/core": "^0.3.0",
    "@cucumber/cucumber-expressions": "^18.0.0",
    "@cucumber/fake-cucumber": "file:./",
    "@cucumber/gherkin": "^33.0.0",
    "@cucumber/gherkin-streams": "^5.0.1",
    "@cucumber/gherkin-utils": "^9.0.0",
    "@cucumber/message-streams": "^4.0.1",
    "@cucumber/messages": "^28.0.0",
    "@cucumber/query": "^13.5.0",
    "@cucumber/tag-expressions": "^6.1.0",
    "globby": "^11.1.0",
    "stack-utils": "2.0.6"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.0.0",
    "@types/stack-utils": "2.0.3",
    "ajv": "^8.11.0",
    "run-for-every-file": "^1.1.0",
    "shx": "^0.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
