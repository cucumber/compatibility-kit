{
  "name": "@cucumber/devkit",
  "version": "0.0.0",
  "description": "Development kit for the cucumber compatibility kit packages",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "copy-samples": "npm run copy-to:javascript && npm run copy-to:ruby",
    "copy-to:javascript": "shx cp -r samples/* ../javascript/features",
    "copy-to:ruby": "shx cp -r samples/* ../ruby/features && rm -rf ../ruby/features/**/*.ts",
    "copy-to:python": "shx cp -r samples/* ../python/src/cucumber_compatibility_kit/features && rm -rf ../python/src/cucumber_compatibility_kit/features/**/*.ts",
    "fix": "biome check --fix --error-on-warnings",
    "generate": "vitest run --update",
    "lint": "biome check --error-on-warnings",
    "postgenerate": "npm run copy-samples",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cucumber/compatibility-kit.git"
  },
  "author": "Aurelien Reeves (https://github.com/aurelien-reeves)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cucumber/compatibility-kit/issues"
  },
  "homepage": "https://github.com/cucumber/compatibility-kit#readme",
  "dependencies": {
    "@cucumber/ci-environment": "^14.0.0",
    "@cucumber/core": "^0.9.0",
    "@cucumber/cucumber-expressions": "^20.0.0",
    "@cucumber/fake-cucumber": "file:./",
    "@cucumber/gherkin": "^41.0.0",
    "@cucumber/gherkin-streams": "^7.0.0",
    "@cucumber/gherkin-utils": "^12.0.0",
    "@cucumber/message-streams": "^5.0.0",
    "@cucumber/messages": "^33.0.0",
    "@cucumber/query": "^16.0.0",
    "@cucumber/tag-expressions": "^10.0.0",
    "globby": "^16.0.0",
    "stack-utils": "2.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cucumber/biome-config": "github:cucumber/biome-config#v0.3.0",
    "@hyperjump/json-schema": "^1.17.6",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^24.0.0",
    "@types/stack-utils": "2.0.3",
    "shx": "^0.4.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
